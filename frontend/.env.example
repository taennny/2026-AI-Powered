# .env.example — 이 파일은 git에 올라갑니다 (키 값 없이 형식만 공유)
# 실제 키는 팀 내부 채널에서 공유받아 .env 파일에 입력하세요

EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_USE_MOCK=true   # 26-5-7 타임라인 mock 데이터 사용
EXPO_PUBLIC_BG_GPS=false    # 백그라운드 GPS 비활성 (expo 앱 실행을 위해 false로 설정 (시뮬레이터 및 배포 시 true로 변경))
EXPO_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_javascript_api_key_here
EXPO_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here


